{
  "name": "huecss",
  "version": "0.0.0",
  "private": true,
  "description": "Your Ember App's description here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "type": "module",
  "imports": {
    "#app/*": "./app/*",
    "#config": "./app/config.ts",
    "#components/*": "./app/components/*",
    "#services/*": "./app/services/*",
    "#test-helpers/*": "./tests/helpers/*",
    "#utils/*": "./app/utils/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "start": "vite",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:fix": "eslint . --fix",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "format": "prettier --write .",
    "lint:prettier": "prettier --check .",
    "test": "vitest",
    "test:ci": "CI=true vitest run",
    "lint:types": "ember-tsc --noEmit"
  },
  "dependencies": {
    "@embroider/macros": "1.20.2",
    "@embroider/router": "3.0.6",
    "@glimmer/component": "2.1.1",
    "chroma-js": "^3.2.0",
    "decorator-transforms": "2.3.1",
    "ember-click-outside": "^6.1.1",
    "ember-modifier": "^4.3.0",
    "ember-source": "6.10.1",
    "ember-strict-application-resolver": "0.1.1",
    "geist": "^1.7.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/plugin-transform-typescript": "7.28.6",
    "@babel/runtime": "7.29.2",
    "@ember/app-tsconfig": "2.0.0",
    "@ember/test-helpers": "5.4.1",
    "@ember/test-waiters": "4.1.1",
    "@embroider/core": "4.4.7",
    "@embroider/vite": "1.7.2",
    "@glint/ember-tsc": "1.5.0",
    "@glint/template": "1.7.7",
    "@glint/tsserver-plugin": "2.4.0",
    "@rollup/plugin-babel": "6.1.0",
    "@types/chroma-js": "^3.1.2",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/browser-preview": "^4.1.5",
    "@vitest/ui": "4.1.5",
    "babel-plugin-ember-template-compilation": "4.0.0",
    "concurrently": "9.2.1",
    "ember-eslint": "0.6.1",
    "ember-vitest": "^0.3.3",
    "eslint": "9.39.4",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "prettier-plugin-ember-template-tag": "2.1.5",
    "testem": "3.17.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-css-modules": "^1.15.0",
    "vite-ember-ssr": "0.1.0-alpha.13",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">= 24"
  },
  "ember": {
    "edition": "octane"
  }
}
