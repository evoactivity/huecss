{
  "extends": "@ember/app-tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "types": [
      "@svg-jar/plugin/client/ember",
      "ember-source/types",
      "@embroider/core/virtual",
      "vite/client",
      "@glint/ember-tsc/types"
    ],
    "paths": {
      "#app/*": ["./app/*"],
      "#config": ["./app/config.ts"],
      "#components/*": ["./app/components/*"],
      "#services/*": ["./app/services/*"],
      "#utils/*": ["./app/utils/*"]
    }
  }
}
